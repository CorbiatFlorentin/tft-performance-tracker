{
  "name": "tft-tracker-backend",
  "version": "1.0.0",
  "description": "TFT Ranked Performance Tracker Backend",
  "main": "dist/index.js",
  "scripts": {
    "dev": "nodemon --exec ts-node src/index.ts",
    "build": "tsc",
