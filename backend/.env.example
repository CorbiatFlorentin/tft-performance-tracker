# Base de données SQLite (aucun serveur nécessaire)
DATABASE_URL="file:./tft.db"

# Clé API Riot Games
# Obtenez votre clé sur https://developer.riotgames.com
# Les clés de développement expirent toutes les 24h
# Pour usage permanent, demandez une clé de production
RIOT_API_KEY=RGAPI-xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx

# Webhook Discord
# Créez un webhook dans vos paramètres de chaîne Discord
# Chaîne → Paramètres → Intégrations → Webhooks → Nouveau Webhook
DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/WEBHOOK_ID/WEBHOOK_TOKEN

# Riot ID du joueur (gameName#tagLine)
SUMMONER_NAME=VotreNomInGame
SUMMONER_TAG=EUW

# Région (EUW1, NA1, KR, EUN1, TR1, JP1, OC1…)
REGION=EUW1

# Intervalle de vérification en millisecondes (300000 = 5 minutes)
POLL_INTERVAL_MS=300000

# Port du serveur backend
PORT=3001
