generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Summoner {
  id         String       @id @default(cuid())
  puuid      String       @unique
  summonerId String       @unique
  gameName   String
  tagLine    String
  region     String       @default("EUW1")
  createdAt  DateTime     @default(now())
  matches    Match[]
  lpHistory  LpSnapshot[]
}

model Match {
  id          String     @id @default(cuid())
  matchId     String     @unique
  summonerId  String
  summoner    Summoner   @relation(fields: [summonerId], references: [id])
  placement   Int
  level       Int
  timeElapsed Int
  gameDate    DateTime
  queueId     Int        @default(1100)
  augments    String     @default("[]")
  units       String     @default("[]")
  lpBefore    Int?
  lpAfter     Int?
  lpDelta     Int?
  tier        String?
  rank        String?
  notifiedAt  DateTime?
  createdAt   DateTime   @default(now())
}

model LpSnapshot {
  id         String   @id @default(cuid())
  summonerId String
  summoner   Summoner @relation(fields: [summonerId], references: [id])
  lp         Int
  tier       String
  rank       String
  recordedAt DateTime @default(now())
}
